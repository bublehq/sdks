{
  "name": "buble/sdk",
  "description": "Official PHP SDK for the Buble public API.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://buble.ai/",
  "keywords": [
    "buble",
    "ai",
    "image-generation",
    "video-generation",
    "chat",
    "openai",
    "anthropic",
    "gemini",
    "sdk"
  ],
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "Buble\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Buble\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src tests --level=max --memory-limit=512M",
    "cs": "phpcs --standard=PSR12 src tests"
  }
}
